OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional: used for public-source health checks and SEC-friendly requests.
# Normal RSS scans do not require this, but SEC pages may require contact info.
IMPACT_CAREER_USER_AGENT="ImpactCareerAgent/0.1 contact: you@example.com"

# Optional: only needed for users who have ImpactAlpha newsletter access in Gmail.
IMPACTALPHA_NEWSLETTER_SENDER=editor@impactalpha.com
IMPACTALPHA_NEWSLETTER_QUERY=

LINKEDIN_ALERT_SENDER=jobalerts-noreply@linkedin.com
GOOGLE_CREDENTIALS_PATH=~/jobsearch/job-radar/config/credentials.json
GOOGLE_TOKEN_PATH=~/jobsearch/job-radar/config/token.json
GOOGLE_SHEET_ID=
WATCHLIST_SHEET_NAME=Organizations

APIFY_API_TOKEN=
APIFY_ACTOR_ID=curious_coder~linkedin-jobs-scraper
APIFY_MAX_RESULTS_PER_QUERY=10
APIFY_ACTOR_TIMEOUT_SECONDS=30
APIFY_MAX_TOTAL_JOBS=300
